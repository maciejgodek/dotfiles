{
    "spacing": 4,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["pulseaudio", "backlight", "idle_inhibitor", "network", "temperature#cpu", "cpu", "memory", "battery", "clock", "tray"],
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/window": {
        "max-length": 50
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "яБ│  {:%Y-%m-%d %H:%M}"
    },
    "cpu": {
        "format": "яЛЫ  {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "яГЙ  {}%"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon}  {percent}%",
        "format-icons": ["ЁЯМХ", "ЁЯМФ", "ЁЯМУ", "ЁЯМТ", "ЁЯМС"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "яЧз  {capacity}%",
        "format-plugged": "яЗж  {capacity}%",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "temperature#cpu": {
        "thermal-zone": 0,
        "critical-threshold": 80,
        "format": "CPU {temperatureC}┬░C",
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "яЗл  ({signalStrength}%)",
        // "format-ethernet": "{ifname}: {ipaddr}/{cidr} яЮЦ",
        "format-ethernet": "яЮЦ  {ipaddr}",
        "format-linked": "яЮЦ  {ifname} (No IP)",
        "format-disconnected": "тЪа  Disconnected"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "яЪй  {icon}яКФ {format_source}",
        "format-muted": "яЪй  {format_source}",
        "format-source": "яД░ {volume}%",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol",
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        },
        "tooltip": "true"
    }

}
